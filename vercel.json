{
  "version": 2,
  "builds": [
    {
      "src": "api/census-zones.py",
      "use": "@vercel/python",
      "config": {
        "includeFiles": [
          "api/_shared/**",
          "data/**"
        ],
        "maxLambdaDuration": 60
      }
    },
    {
      "src": "api/calculate-population.py",
      "use": "@vercel/python",
      "config": {
        "includeFiles": [
          "api/_shared/**",
          "data/**"
        ],
        "maxLambdaDuration": 60
      }
    },
    {
      "src": "api/zone-stats/**/*.py",
      "use": "@vercel/python",
      "config": {
        "includeFiles": [
          "api/_shared/**",
          "data/**"
        ],
        "maxLambdaDuration": 60
      }
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/style.css",
      "dest": "/public/style.css"
    },
    {
      "src": "/script.js",
      "dest": "/public/script.js"
    },
    {
      "src": "/(.*)",
      "dest": "/public/index.html"
    }
  ]
}
