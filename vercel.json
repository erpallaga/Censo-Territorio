{
  "version": 2,
  "functions": {
    "api/calculate-population.py": {
      "includeFiles": "data/**",
      "maxDuration": 60
    },
    "api/census-zones.py": {
      "includeFiles": "data/**",
      "maxDuration": 60
    },
    "api/zone-stats/**/*.py": {
      "includeFiles": "data/**",
      "maxDuration": 60
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/style.css",
      "dest": "/public/style.css"
    },
    {
      "src": "/script.js",
      "dest": "/public/script.js"
    },
    {
      "src": "/(.*)",
      "dest": "/public/index.html"
    }
  ],
  "cleanUrls": true,
  "$schema": "https://openapi.vercel.sh/vercel.json"
}